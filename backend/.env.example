# Supabase — Settings > API in your Supabase project dashboard
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-public-key
# Service role key — never expose this to the frontend
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Server
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:5173

# Broker account — create a regular Supabase auth user to act as the exchange
# counterparty, then paste its UUID here.
BROKER_USER_ID=

# Gemini — reserved for the future AI insight feature
GEMINI_API_KEY=
